generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRoleCode {
  SUPER_ADMIN
  TENANT_ADMIN
  MANAGER
  CASHIER
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  EXPIRED
  CANCELED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum InventoryAction {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  SALE
  REFUND
}

enum SaleStatus {
  COMPLETED
  REFUNDED
  CANCELED
}

enum PaymentMethod {
  CASH
  CARD
  QR
  WALLET
  MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIAL
}

enum OrderSource {
  POS
  WEB
  API
}

enum AuditActorType {
  USER
  SYSTEM
  SUPER_ADMIN
}

enum ReportPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum SupportTier {
  BASIC
  PRIORITY
  PREMIUM
  ENTERPRISE
}

model Tenant {
  id            String          @id @default(uuid())
  name          String
  slug          String          @unique
  status        TenantStatus    @default(ACTIVE)
  timezone      String          @default("UTC")
  currency      String          @default("USD")
  domain        String?
  logoUrl       String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  users         User[]
  roles         Role[]
  categories    Category[]
  products      Product[]
  inventoryLogs InventoryLog[]
  counters      Counter[]
  carts         Cart[]
  sales         Sale[]
  payments      Payment[]
  paymentTransactions PaymentTransaction[]
  subscriptions Subscription[]
  settings      Setting?
  reportSnapshots ReportSnapshot[]
  auditLogs     AuditLog[]

  @@index([status])
}

model Plan {
  id                   String        @id @default(uuid())
  code                 String        @unique
  name                 String
  description          String?
  monthlyPrice         Decimal       @db.Decimal(12, 2)
  yearlyPrice          Decimal?      @db.Decimal(12, 2)
  maxProducts          Int?
  maxOrdersPerYear     Int?
  maxStaffAccounts     Int?
  domainIncluded       Boolean       @default(true)
  hostingPackage       String
  maintenanceIncluded  Boolean       @default(true)
  supportTier          SupportTier   @default(BASIC)
  isActive             Boolean       @default(true)
  metadata             Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  subscriptions        Subscription[]
  planFeatures         PlanFeature[]
}

model Feature {
  id               String       @id @default(uuid())
  key              String       @unique
  name             String
  description      String?
  category         String?
  isMetered        Boolean      @default(false)
  defaultLimit     Int?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  planFeatures     PlanFeature[]
}

model PlanFeature {
  id               String       @id @default(uuid())
  planId           String
  featureId        String
  enabled          Boolean      @default(false)
  limitValue       Int?
  metadata         Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  plan             Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature          Feature      @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([planId, featureId])
  @@index([featureId])
}

model Subscription {
  id               String             @id @default(uuid())
  tenantId         String
  planId           String
  status           SubscriptionStatus @default(ACTIVE)
  startsAt         DateTime
  endsAt           DateTime?
  trialEndsAt      DateTime?
  autoRenew        Boolean            @default(true)
  canceledAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan             Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([tenantId, status])
}

model Role {
  id               String       @id @default(uuid())
  tenantId         String?
  code             UserRoleCode
  name             String
  description      String?
  isSystem         Boolean      @default(true)
  permissions      Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant           Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users            User[]

  @@unique([tenantId, code])
}

model User {
  id               String       @id @default(uuid())
  tenantId         String?
  roleId           String
  email            String       @unique
  passwordHash     String
  firstName        String
  lastName         String
  phone            String?
  isActive         Boolean      @default(true)
  lastLoginAt      DateTime?
  refreshTokenHash String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  tenant           Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  role             Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)
  inventoryLogs    InventoryLog[] @relation("InventoryActor")
  carts            Cart[]
  cashierSales     Sale[]       @relation("CashierSales")
  managerSales     Sale[]       @relation("ManagerSales")
  refundedSales    Sale[]       @relation("RefundedSales")
  payments         Payment[]    @relation("PaymentCreator")

  @@index([tenantId, roleId])
}

model Category {
  id               String       @id @default(uuid())
  tenantId         String
  name             String
  description      String?
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products         Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Product {
  id               String        @id @default(uuid())
  tenantId         String
  categoryId       String?
  name             String
  sku              String
  barcode          String?
  description      String?
  imageUrl         String?
  price            Decimal       @db.Decimal(12, 2)
  costPrice        Decimal       @db.Decimal(12, 2)
  stockQuantity    Int           @default(0)
  lowStockThreshold Int          @default(10)
  status           ProductStatus @default(ACTIVE)
  hasVariants      Boolean       @default(false)
  metadata         Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category         Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  inventoryLogs    InventoryLog[]
  cartItems        CartItem[]
  saleItems        SaleItem[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([tenantId, status])
  @@index([tenantId, name])
}

model Counter {
  id               String       @id @default(uuid())
  tenantId         String
  name             String
  code             String
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales            Sale[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model InventoryLog {
  id               String          @id @default(uuid())
  tenantId         String
  productId        String
  action           InventoryAction
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  reason           String?
  referenceType    String?
  referenceId      String?
  createdById      String?
  createdAt        DateTime        @default(now())

  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy        User?           @relation("InventoryActor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, action])
  @@index([productId, createdAt])
}

model Cart {
  id               String       @id @default(uuid())
  tenantId         String
  cashierId        String
  name             String?
  status           String       @default("ACTIVE")
  subtotal         Decimal      @db.Decimal(12, 2)
  discountAmount   Decimal      @default(0) @db.Decimal(12, 2)
  taxAmount        Decimal      @default(0) @db.Decimal(12, 2)
  total            Decimal      @db.Decimal(12, 2)
  heldAt           DateTime?
  resumedAt        DateTime?
  expiresAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashier          User         @relation(fields: [cashierId], references: [id], onDelete: Restrict)
  items            CartItem[]

  @@index([tenantId, status])
}

model CartItem {
  id               String       @id @default(uuid())
  cartId           String
  productId        String
  quantity         Int
  unitPrice        Decimal      @db.Decimal(12, 2)
  discountAmount   Decimal      @default(0) @db.Decimal(12, 2)
  taxAmount        Decimal      @default(0) @db.Decimal(12, 2)
  lineTotal        Decimal      @db.Decimal(12, 2)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  cart             Cart         @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product          Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([cartId, productId])
}

model Sale {
  id               String       @id @default(uuid())
  tenantId         String
  counterId        String?
  saleNumber       String
  source           OrderSource  @default(POS)
  status           SaleStatus   @default(COMPLETED)
  customerName     String?
  customerPhone    String?
  subtotal         Decimal      @db.Decimal(12, 2)
  discountAmount   Decimal      @default(0) @db.Decimal(12, 2)
  taxAmount        Decimal      @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal      @db.Decimal(12, 2)
  paidAmount       Decimal      @default(0) @db.Decimal(12, 2)
  changeAmount     Decimal      @default(0) @db.Decimal(12, 2)
  notes            String?
  cashierId        String
  managerId        String?
  refundedById     String?
  refundReason     String?
  refundedAt       DateTime?
  completedAt      DateTime     @default(now())
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  counter          Counter?     @relation(fields: [counterId], references: [id], onDelete: SetNull)
  cashier          User         @relation("CashierSales", fields: [cashierId], references: [id], onDelete: Restrict)
  manager          User?        @relation("ManagerSales", fields: [managerId], references: [id], onDelete: SetNull)
  refundedBy       User?        @relation("RefundedSales", fields: [refundedById], references: [id], onDelete: SetNull)
  items            SaleItem[]
  payments         Payment[]

  @@unique([tenantId, saleNumber])
  @@index([tenantId, completedAt])
}

model SaleItem {
  id               String       @id @default(uuid())
  saleId           String
  productId        String
  productName      String
  sku              String
  quantity         Int
  unitPrice        Decimal      @db.Decimal(12, 2)
  costPrice        Decimal      @db.Decimal(12, 2)
  discountAmount   Decimal      @default(0) @db.Decimal(12, 2)
  taxAmount        Decimal      @default(0) @db.Decimal(12, 2)
  lineTotal        Decimal      @db.Decimal(12, 2)
  createdAt        DateTime     @default(now())

  sale             Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product          Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId])
}

model Payment {
  id               String       @id @default(uuid())
  tenantId         String
  saleId           String
  method           PaymentMethod
  status           PaymentStatus @default(PENDING)
  provider         String
  amount           Decimal      @db.Decimal(12, 2)
  currency         String
  referenceNumber  String?
  paidAt           DateTime?
  createdById      String?
  metadata         Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale             Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  createdBy        User?        @relation("PaymentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  transactions     PaymentTransaction[]

  @@index([tenantId, status])
  @@index([saleId])
}

model PaymentTransaction {
  id                    String        @id @default(uuid())
  tenantId              String
  paymentId             String
  provider              String
  providerTransactionId String?
  requestPayload        Json?
  responsePayload       Json?
  status                PaymentStatus
  amount                Decimal       @db.Decimal(12, 2)
  currency              String
  reconciledAt          DateTime?
  failureReason         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payment               Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([provider, providerTransactionId])
}

model Setting {
  id               String       @id @default(uuid())
  tenantId         String       @unique
  businessName     String
  taxRate          Decimal      @default(0) @db.Decimal(5, 2)
  receiptFooter    String?
  logoUrl          String?
  currency         String       @default("USD")
  timezone         String       @default("UTC")
  paymentConfig    Json?
  receiptConfig    Json?
  brandingConfig   Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ReportSnapshot {
  id               String       @id @default(uuid())
  tenantId         String
  period           ReportPeriod
  periodStart      DateTime
  periodEnd        DateTime
  payload          Json
  createdAt        DateTime     @default(now())

  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, period, periodStart, periodEnd])
  @@index([tenantId, period])
}

model AuditLog {
  id               String       @id @default(uuid())
  tenantId         String?
  actorType        AuditActorType
  actorId          String?
  action           String
  entity           String
  entityId         String?
  details          Json?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime     @default(now())

  tenant           Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([entity, entityId])
}
